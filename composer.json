{
    "name": "laravel-chronicle/core",
    "description": "Tamper-evident audit ledger for Laravel applications.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "audit log",
        "audit trail",
        "append-only log",
        "event log",
        "ledger",
        "security",
        "hash chain",
        "compliance",
        "chronicle"
    ],
    "homepage": "https://github.com/laravel-chronicle/core",
    "support": {
        "issues": "https://github.com/laravel-chronicle/core/issues"
    },
    "authors": [
        {
            "name": "Vasileios Ntoufoudis",
            "email": "info@ntoufouis.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0||^12.0",
        "ext-sodium": "*"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^9.0||^10.0",
        "pestphp/pest": "^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^3.0||^4.0"
    },
    "autoload": {
        "psr-4": {
            "Chronicle\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Chronicle\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Chronicle\\ChronicleServiceProvider"
            ],
            "aliases": {
                "chronicle": "Chronicle\\Facades\\Chronicle"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=2G",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --parallel --coverage",
        "format": "vendor/bin/pint"
    }
}
